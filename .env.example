# AI assessment reports (Amazon Bedrock via the Vercel AI SDK).
# Without valid AWS credentials the report call fails and the app returns the
# static fallback report. Credentials use the standard AWS environment variables.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Bedrock model used for report generation. The main retaind app uses Amazon Nova.
AI_MODEL_ID=us.amazon.nova-pro-v1:0
# Postgres (shared with the main retaind app in dev). Leave empty to run with no
# database (persistence is skipped). Tables/migrations are owned by the retaind
# repo (its CI/CD applies them to the real DB).
DATABASE_URL=postgresql://postgres:password@localhost:5432/retaind_dev

# Abuse control for AI report generation uses the free open-source FingerprintJS
# (computed client-side, no key required). A device may generate one report per
# assessment type; repeats are asked to sign up.
# Where the "you've already generated a report" CTA sends repeat users.
NEXT_PUBLIC_SIGNUP_URL=
